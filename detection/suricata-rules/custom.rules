alert tcp $HOME_NET any -> $HOME_NET any (msg:"LOCAL SCAN Internal horizontal SYN scan T1046"; flow:to_server; flags:S; threshold:type both, track by_src, count 20, seconds 10; classtype:attempted-recon; sid:1000001; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"LOCAL SCAN External-to-internal SYN scan T1046"; flow:to_server; flags:S; threshold:type both, track by_src, count 20, seconds 10; classtype:attempted-recon; sid:1000002; rev:1;)
