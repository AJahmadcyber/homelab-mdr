<group name="sysmon,credential_access,mitre,">
  <!-- T1003.001 - LSASS dump via comsvcs.dll MiniDump (Sysmon EID1 command line) -->
  <rule id="100311" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)comsvcs.{0,40}minidump</field>
    <description>Possible LSASS credential dumping via comsvcs.dll MiniDump ($(win.eventdata.image)) - T1003.001</description>
    <mitre><id>T1003.001</id></mitre>
    <group>credential_access,lsass_access,</group>
  </rule>

  <!-- T1003.001 - LSASS dump-level ProcessAccess (Sysmon EID10). May be dropped if CallTrace exceeds event-size limit -->
  <rule id="100310" level="12">
    <if_group>sysmon_event_10</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)\\lsass\.exe$</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">(?i)0x1010|0x1410|0x1438|0x143a|0x1fffff|0x1f1fff|0x1f3fff</field>
    <description>Possible LSASS credential dumping: dump-level access to lsass.exe from $(win.eventdata.sourceImage) - T1003.001</description>
    <mitre><id>T1003.001</id></mitre>
    <group>credential_access,lsass_access,</group>
  </rule>
</group>
