<group name="sysmon,credential_access,mitre,">
  <rule id="100311" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)comsvcs.{0,40}minidump</field>
    <description>Possible LSASS credential dumping via comsvcs.dll MiniDump ($(win.eventdata.image)) - T1003.001</description>
    <mitre><id>T1003.001</id></mitre>
    <group>credential_access,lsass_access,</group>
  </rule>

  <rule id="100310" level="12">
    <if_group>sysmon_event_10</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)\\lsass\.exe$</field>
    <field name="win.eventdata.sourceImage" negate="yes" type="pcre2">(?i)\\(wazuh-agent|MsMpEng)\.exe$</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">(?i)0x1010|0x1410|0x1438|0x143a|0x1fffff|0x1f1fff|0x1f3fff</field>
    <description>Possible LSASS credential dumping: dump-level access to lsass.exe from $(win.eventdata.sourceImage) - T1003.001</description>
    <mitre><id>T1003.001</id></mitre>
    <group>credential_access,lsass_access,</group>
  </rule>

  <rule id="100312" level="13">
    <if_sid>91802</if_sid>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)invoke-mimikatz|sekurlsa::|logonpasswords|dumpcreds|lsadump::|kerberos::</field>
    <description>Possible Mimikatz credential dumping detected in PowerShell script block - T1003.001</description>
    <mitre><id>T1003.001</id></mitre>
    <group>credential_access,mimikatz,</group>
  </rule>

  <!-- T1555.003/T1539 - Browser credential/cookie store access (esentutl LOLBAS, sqlite, copy) -->
  <rule id="100313" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)login data|\\User Data\\.{0,40}cookies</field>
    <description>Possible browser credential/cookie theft: process accessing browser credential store ($(win.eventdata.image)) - T1555.003</description>
    <mitre><id>T1555.003</id></mitre>
    <group>credential_access,browser_credential_theft,</group>
  </rule>
</group>
